{
  "compilerOptions": {
    "pretty": true,
    "strict": true,
    "newLine": "lf",
    "jsx": "react-jsx",
    "module": "esnext",
    "rootDir": "./dts",
    "target": "esnext",
    "skipLibCheck": true,
    "importHelpers": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitOverride": true,
    "noUnusedParameters": true,
    "moduleResolution": "bundler",
    "paths": {
      "/*": [
        "./dts/*"
      ]
    }
  },
  "include": [
    "dts/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
