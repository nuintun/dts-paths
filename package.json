{
  "name": "dts-paths",
  "version": "2.1.1",
  "description": "Replace alias paths with relative paths after typescript compilation.",
  "type": "module",
  "sideEffects": false,
  "main": "cjs/index.cjs",
  "module": "esm/index.js",
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs",
      "default": "./esm/index.js"
    }
  },
  "files": [
    "cjs",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuintun/dts-paths.git"
  },
  "keywords": [
    "dts",
    "tsc",
    "alias",
    "paths",
    "typescript",
    "compilation",
    "absolute path",
    "relative path"
  ],
  "author": {
    "name": "nuintun",
    "email": "nuintun@qq.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nuintun/dts-paths/issues"
  },
  "homepage": "https://github.com/nuintun/dts-paths#readme",
  "scripts": {
    "lint": "tsc --noEmit",
    "pretest": "pnpm build:main",
    "clean": "node tools/clean.js",
    "prepublishOnly": "pnpm build",
    "test": "node --test tests/index.js",
    "build:cjs": "rollup -c tools/rollup.cjs.js",
    "build:esm": "rollup -c tools/rollup.esm.js",
    "build:fix-types": "node tools/fix-types.js",
    "build": "pnpm clean && pnpm build:main && pnpm format",
    "format": "prettier --write . --ignore-path .prettierignore",
    "build:main": "pnpm build:cjs && pnpm build:esm && pnpm build:fix-types"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
